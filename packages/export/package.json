{
	"name": "@effect-motion/export",
	"version": "0.5.0",
	"description": "Node-only export tools for effect-motion: render scenes to PNG frames (ThorVG) and encode to video (ffmpeg)",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/julia-script/effect-motion.git",
		"directory": "packages/export"
	},
	"homepage": "https://github.com/julia-script/effect-motion#readme",
	"bugs": "https://github.com/julia-script/effect-motion/issues",
	"keywords": [
		"effect",
		"motion",
		"export",
		"thorvg",
		"png",
		"ffmpeg",
		"video"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
		"test": "vitest run",
		"check": "tsc --noEmit"
	},
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"@effect-motion/thorvg": "workspace:^",
		"effect-motion": "workspace:^",
		"ffmpeg-static": "^5.3.0"
	},
	"peerDependencies": {
		"effect": ">=4.0.0-beta.98"
	},
	"devDependencies": {
		"@effect/platform-node": "4.0.0-beta.98",
		"@types/node": "^26.1.1",
		"effect": "4.0.0-beta.98",
		"typescript": "^7.0.2",
		"vitest": "^4.1.10"
	}
}
