{
	"name": "@effect-motion/react",
	"version": "0.2.0",
	"description": "React bindings for effect-motion: usePlayer hook and Player component",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/julia-script/effect-motion.git",
		"directory": "packages/react"
	},
	"homepage": "https://github.com/julia-script/effect-motion#readme",
	"bugs": "https://github.com/julia-script/effect-motion/issues",
	"keywords": [
		"effect",
		"motion",
		"react",
		"animation",
		"motion-graphics"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
		"test": "vitest run",
		"check": "tsc --noEmit"
	},
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"effect-motion": "workspace:^"
	},
	"peerDependencies": {
		"effect": ">=4.0.0-beta.94",
		"react": ">=18"
	},
	"devDependencies": {
		"@testing-library/react": "^16.3.0",
		"@types/react": "^19.2.0",
		"@types/react-dom": "^19.2.0",
		"effect": "4.0.0-beta.94",
		"happy-dom": "^20.10.6",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"typescript": "^7.0.2",
		"vitest": "^4.1.10"
	}
}
