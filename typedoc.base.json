{
	"$schema": "https://typedoc.org/schema.json",
	"plugin": ["typedoc-plugin-markdown"],
	"readme": "none",
	"excludeExternals": true,
	"excludeInternal": true,
	"githubPages": false,
	"hidePageHeader": true,
	"hideBreadcrumbs": true,
	"useCodeBlocks": true,
	"expandObjects": true,
	"parametersFormat": "table",
	"disableSources": false,
	"sourceLinkTemplate": "https://github.com/julia-script/effect-motion/blob/main/{path}#L{line}",
	"skipErrorChecking": true,
	"sort": ["alphabetical"],
	"logLevel": "Warn"
}
